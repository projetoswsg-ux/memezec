<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Monero - Velas Gigantes 3D</title>
    <style>
        body, html {
            margin: 0; padding: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            background-color: #0a0a0f;
            touch-action: none;
            user-select: none;
            font-family: 'Segoe UI', Arial, sans-serif;
            cursor: default;
            color: #eee;
        }
        #canvas-container {
            width: 100%; height: 100%;
            display: block;
        }
        #crosshair {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            color: rgba(255,255,255,0.2);
            font-size: 30px;
            pointer-events: none;
            z-index: 5;
            opacity: 0;
            transition: opacity 0.3s;
            font-family: monospace;
        }
        #crosshair.visivel { opacity: 1; }
        #instrucoes {
            position: absolute;
            top: 20px;
            left: 20px;
            color: #ccc;
            pointer-events: none;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);
            background: rgba(20,20,30,0.7);
            backdrop-filter: blur(6px);
            padding: 16px 20px;
            border-radius: 16px;
            border: 1px solid #444;
            transition: opacity 0.6s ease-out;
            z-index: 10;
            font-size: 14px;
            max-width: 280px;
            box-shadow: 0 0 30px rgba(0,0,0,0.6);
        }
        .dica { margin: 4px 0; line-height: 1.4; }
        .titulo { font-size: 20px; font-weight: bold; color: #f90; text-shadow: 0 0 20px #f60; margin-bottom: 6px; }
        #status-ws {
            position: absolute;
            bottom: 30px;
            right: 30px;
            color: #888;
            font-size: 13px;
            background: rgba(0,0,0,0.6);
            padding: 8px 14px;
            border-radius: 20px;
            border: 1px solid #444;
            z-index: 20;
            pointer-events: none;
        }
        #status-ws.conectado { color: #4caf50; border-color: #4caf50; }
        #status-ws.desconectado { color: #f44336; border-color: #f44336; }
        #aviso-portal {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: #fff;
            background: rgba(40,40,60,0.9);
            backdrop-filter: blur(6px);
            padding: 12px 24px;
            border-radius: 40px;
            font-size: 18px;
            font-weight: bold;
            border: 2px solid #666;
            box-shadow: 0 0 30px #000;
            z-index: 30;
            opacity: 0;
            transition: opacity 0.4s;
            pointer-events: none;
            text-shadow: 0 0 10px rgba(0,0,0,0.8);
        }
        #aviso-portal.visivel { opacity: 1; }
        #info-velas {
            position: absolute;
            bottom: 80px;
            left: 30px;
            color: #aaa;
            font-size: 13px;
            background: rgba(0,0,0,0.5);
            padding: 6px 12px;
            border-radius: 12px;
            pointer-events: none;
            z-index: 15;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>
    <div id="instrucoes">
        <div class="titulo">⬡ MONERO - VELAS GIGANTES</div>
        <div class="dica">🖱️ <b>Left drag</b> / <b>WASD</b> → Walk</div>
        <div class="dica">🖱️ <b>Right drag</b> / <b>Mouse</b> → Look</div>
        <div class="dica" style="margin-top:8px; color:#4caf50;">🟢 Verde = Alta (sobe do chão)</div>
        <div class="dica" style="color:#f44336;">🔴 Vermelho = Baixa (cai do céu)</div>
        <div class="dica" style="margin-top:8px; color:#888;">⌨️ Pressione <b>T</b> para testar vela</div>
    </div>
    <div id="status-ws" class="desconectado">⏳ Conectando...</div>
    <div id="aviso-portal">Portal...</div>
    <div id="crosshair">+</div>
    <div id="info-velas">Velas ativas: 0</div>
    <div id="canvas-container"></div>

    <script>
        // ============================================================
        //  1. CONFIGURAÇÕES GLOBAIS
        // ============================================================
        let scene, camera, renderer;
        let clock = new THREE.Clock();

        // Controles
        const touchEsquerdo = { ativo: false, id: null, inicioX: 0, inicioY: 0, deltaX: 0, deltaY: 0 };
        const touchDireito = { ativo: false, id: null, ultimoX: 0, ultimoY: 0 };
        const teclas = { w: false, a: false, s: false, d: false, t: false };
        let mousePreso = false;
        const velMovimento = 8.0;
        const velVisao = 0.005;
        const alturaOlhos = 1.6;
        let cameraEuler = new THREE.Euler(0, 0, 0, 'YXZ');

        const corCeu = 0x0a0a14;

        // Elementos
        let portalPretoEstrelas = null;
        const areaPortal = { minX: -1.5, maxX: 1.5, minZ: 19.0, maxZ: 22.0 };
        const DESTINO_MONEROVERSE = 'https://moneroverse.com/universe.html';
        let jaRedirecionouPortal = false;
        const aviso = document.getElementById('aviso-portal');
        const crosshair = document.getElementById('crosshair');
        const statusWs = document.getElementById('status-ws');
        const infoVelas = document.getElementById('info-velas');

        // Limite do muro
        const RAIO_MURO = 19.5;

        // ============================================================
        //  2. SISTEMA DE VELAS GIGANTES
        // ============================================================
        const velas = [];
        const VIDA_TOTAL = 10.0;
        const DURACAO_CRESCIMENTO = 2.0;
        const DURACAO_DECOLAGEM = 2.0;
        const ALTURA_MIN = 8.0;
        const ALTURA_MAX = 18.0;
        const DISTANCIA_MIN_JOGADOR = 5.0; // distância mínima do centro do jogador

        function gerarPosicaoValida() {
            // Posição aleatória dentro do raio do muro, mas longe do jogador
            const maxAttempts = 50;
            for (let attempt = 0; attempt < maxAttempts; attempt++) {
                const ang = Math.random() * Math.PI * 2;
                const raio = Math.random() * (RAIO_MURO - 1.0);
                const x = Math.cos(ang) * raio;
                const z = Math.sin(ang) * raio;
                // Verifica distância ao jogador
                const dx = x - camera.position.x;
                const dz = z - camera.position.z;
                const dist = Math.sqrt(dx*dx + dz*dz);
                if (dist > DISTANCIA_MIN_JOGADOR) {
                    return { x, z };
                }
            }
            // Fallback: posição à frente do jogador
            const forward = new THREE.Vector3(0, 0, -1);
            forward.applyQuaternion(camera.quaternion);
            forward.y = 0;
            forward.normalize();
            const dist = DISTANCIA_MIN_JOGADOR + 2;
            const pos = camera.position.clone().add(forward.clone().multiplyScalar(dist));
            // Garantir que fique dentro do raio
            const distCentro = Math.sqrt(pos.x*pos.x + pos.z*pos.z);
            if (distCentro > RAIO_MURO - 1) {
                const ang = Math.atan2(pos.z, pos.x);
                pos.x = Math.cos(ang) * (RAIO_MURO - 1);
                pos.z = Math.sin(ang) * (RAIO_MURO - 1);
            }
            return { x: pos.x, z: pos.z };
        }

        function criarVela(open, close, high, low, tipo) {
            const diff = Math.abs(close - open);
            const variacaoPercentual = diff / open;
            let altura = Math.min(variacaoPercentual * 30, ALTURA_MAX);
            if (altura < ALTURA_MIN) altura = ALTURA_MIN;

            const raioCorpo = 0.8 + (altura / ALTURA_MAX) * 0.6;
            const raioPavio = 0.12;

            const grupo = new THREE.Group();

            // Corpo
            const corpoGeo = new THREE.CylinderGeometry(raioCorpo, raioCorpo, altura, 12);
            const cor = tipo === 'green' ? 0x4caf50 : 0xf44336;
            const material = new THREE.MeshStandardMaterial({
                color: cor,
                emissive: cor,
                emissiveIntensity: 0.5,
                roughness: 0.3,
                metalness: 0.1
            });
            const corpo = new THREE.Mesh(corpoGeo, material);
            corpo.position.y = altura / 2;
            corpo.castShadow = true;
            corpo.receiveShadow = true;
            grupo.add(corpo);

            // Pavio
            const pavioAlt = Math.max((high - low) / open * 30, 0.5);
            const pavioGeo = new THREE.CylinderGeometry(raioPavio, raioPavio, pavioAlt, 6);
            const pavioMat = new THREE.MeshStandardMaterial({
                color: 0xcccccc,
                emissive: 0x555555,
                emissiveIntensity: 0.2
            });
            const pavio = new THREE.Mesh(pavioGeo, pavioMat);
            pavio.position.y = altura / 2;
            grupo.add(pavio);

            // Posição válida
            const pos = gerarPosicaoValida();
            grupo.position.set(pos.x, 0, pos.z);

            // Rotação aleatória
            grupo.rotation.y = Math.random() * Math.PI * 2;

            // Configuração inicial
            if (tipo === 'green') {
                grupo.scale.y = 0;
                grupo.position.y = 0;
                grupo.userData.alturaFinal = altura;
                grupo.userData.fase = 'crescendo';
                grupo.userData.tempoFase = 0;
            } else {
                const alturaCeu = 25 + Math.random() * 15;
                grupo.position.y = alturaCeu;
                grupo.scale.y = 1;
                grupo.userData.alturaFinal = 0;
                grupo.userData.fase = 'caindo';
                grupo.userData.tempoFase = 0;
                grupo.userData.alturaInicial = alturaCeu;
            }

            scene.add(grupo);

            const vela = {
                grupo: grupo,
                tipo: tipo,
                tempoCriacao: clock.elapsedTime,
                ativo: true,
                altura: altura,
                pavioAlt: pavioAlt
            };
            velas.push(vela);
            atualizarInfoVelas();
            return vela;
        }

        function atualizarVelas(deltaTime) {
            const agora = clock.elapsedTime;
            for (let i = velas.length - 1; i >= 0; i--) {
                const v = velas[i];
                const idade = agora - v.tempoCriacao;
                if (idade > VIDA_TOTAL) {
                    scene.remove(v.grupo);
                    v.grupo.children.forEach(child => {
                        if (child.geometry) child.geometry.dispose();
                        if (child.material) child.material.dispose();
                    });
                    velas.splice(i, 1);
                    continue;
                }

                const grupo = v.grupo;
                const user = grupo.userData;
                const fase = user.fase;
                user.tempoFase += deltaTime;

                if (v.tipo === 'green') {
                    if (fase === 'crescendo') {
                        const progresso = Math.min(user.tempoFase / DURACAO_CRESCIMENTO, 1);
                        const eased = progresso * progresso * (3 - 2 * progresso);
                        grupo.scale.y = eased;
                        grupo.position.y = (user.alturaFinal / 2) * eased;
                        if (progresso >= 1) {
                            user.fase = 'decolando';
                            user.tempoFase = 0;
                        }
                    } else if (fase === 'decolando') {
                        const progresso = Math.min(user.tempoFase / DURACAO_DECOLAGEM, 1);
                        const alturaExtra = progresso * 3.0;
                        grupo.position.y = (user.alturaFinal / 2) + alturaExtra;
                        grupo.rotation.x = -progresso * 0.05;
                        if (progresso >= 1) {
                            user.fase = 'pronto';
                        }
                    }
                } else {
                    if (fase === 'caindo') {
                        const progresso = Math.min(user.tempoFase / DURACAO_CRESCIMENTO, 1);
                        const eased = progresso * progresso * (3 - 2 * progresso);
                        const yAtual = user.alturaInicial * (1 - eased);
                        grupo.position.y = yAtual;
                        grupo.rotation.z = progresso * 0.1;
                        if (progresso >= 1) {
                            user.fase = 'pronto';
                            grupo.position.y = 0;
                            grupo.rotation.z = 0;
                        }
                    }
                }
            }
            atualizarInfoVelas();
        }

        function atualizarInfoVelas() {
            infoVelas.textContent = 'Velas ativas: ' + velas.length;
        }

        // ============================================================
        //  3. WEBSOCKET BINANCE FUTURES
        // ============================================================
        let ws = null;
        let reconectarTimer = null;

        function conectarWebSocket() {
            if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) return;
            statusWs.textContent = '⏳ Conectando...';
            statusWs.className = 'desconectado';

            ws = new WebSocket('wss://fstream.binance.com/ws/xmrusdt@kline_1m');

            ws.onopen = function() {
                console.log('WebSocket conectado');
                statusWs.textContent = '🟢 Conectado (XMRUSDT 1m)';
                statusWs.className = 'conectado';
            };

            ws.onmessage = function(event) {
                try {
                    const data = JSON.parse(event.data);
                    if (data.e === 'kline') {
                        const k = data.k;
                        if (k.x === true) {
                            const open = parseFloat(k.o);
                            const close = parseFloat(k.c);
                            const high = parseFloat(k.h);
                            const low = parseFloat(k.l);
                            const tipo = close > open ? 'green' : 'red';
                            criarVela(open, close, high, low, tipo);
                            // Limite de velas
                            if (velas.length > 40) {
                                const remover = velas.splice(0, velas.length - 40);
                                remover.forEach(v => {
                                    scene.remove(v.grupo);
                                    v.grupo.children.forEach(child => {
                                        if (child.geometry) child.geometry.dispose();
                                        if (child.material) child.material.dispose();
                                    });
                                });
                            }
                        }
                    }
                } catch (e) {
                    console.warn('Erro ao processar mensagem WS:', e);
                }
            };

            ws.onerror = function(err) {
                console.warn('WebSocket erro:', err);
                statusWs.textContent = '⚠️ Erro na conexão';
                statusWs.className = 'desconectado';
            };

            ws.onclose = function() {
                console.log('WebSocket fechado, reconectando em 5s...');
                statusWs.textContent = '🔄 Reconectando...';
                statusWs.className = 'desconectado';
                if (reconectarTimer) clearTimeout(reconectarTimer);
                reconectarTimer = setTimeout(conectarWebSocket, 5000);
            };
        }

        // ============================================================
        //  4. FUNÇÃO DE TESTE (TECLA T)
        // ============================================================
        function gerarVelaTeste() {
            const open = 200 + Math.random() * 50;
            const close = open + (Math.random() - 0.5) * 30;
            const high = Math.max(open, close) + Math.random() * 10;
            const low = Math.min(open, close) - Math.random() * 10;
            const tipo = close > open ? 'green' : 'red';
            criarVela(open, close, high, low, tipo);
        }

        // ============================================================
        //  5. CENA 3D
        // ============================================================
        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(corCeu);

            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 100);
            camera.position.set(0, alturaOlhos, 12.0);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 0.8;
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            // Luzes
            const luzAmbiente = new THREE.AmbientLight(0x334466, 0.5);
            scene.add(luzAmbiente);
            const luzDirecional = new THREE.DirectionalLight(0xffaa66, 0.7);
            luzDirecional.position.set(5, 20, 10);
            luzDirecional.castShadow = true;
            luzDirecional.shadow.camera.top = 30;
            luzDirecional.shadow.camera.bottom = -5;
            luzDirecional.shadow.camera.left = -25;
            luzDirecional.shadow.camera.right = 25;
            scene.add(luzDirecional);
            const luzFill = new THREE.PointLight(0x446688, 0.3, 25);
            luzFill.position.set(-8, 4, -5);
            scene.add(luzFill);

            // Chão
            criarChao();
            // Muro
            criarMuroPedra();
            // Portal
            criarPortalPretoEstrelas();

            // Conectar WebSocket
            conectarWebSocket();

            // Eventos
            window.addEventListener('resize', onWindowResize, false);
            const areaTouch = document.body;
            areaTouch.addEventListener('touchstart', onTouchStart, { passive: false });
            areaTouch.addEventListener('touchmove', onTouchMove, { passive: false });
            areaTouch.addEventListener('touchend', onTouchEnd, { passive: false });
            areaTouch.addEventListener('touchcancel', onTouchEnd, { passive: false });
            document.addEventListener('keydown', onKeyDown, false);
            document.addEventListener('keyup', onKeyUp, false);
            renderer.domElement.addEventListener('click', onCanvasClick, false);
            document.addEventListener('mousemove', onMouseMove, false);
            document.addEventListener('pointerlockchange', onPointerLockChange, false);

            animate();
        }

        // ============================================================
        //  6. CHÃO E MURO
        // ============================================================
        function criarTexturaPedraEscura() {
            const canvas = document.createElement('canvas');
            canvas.width = 512; canvas.height = 512;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#2a2a30';
            ctx.fillRect(0, 0, 512, 512);
            for (let i = 0; i < 6000; i++) {
                const x = Math.random() * 512, y = Math.random() * 512;
                const r = 1 + Math.random() * 4;
                const brilho = 50 + Math.random() * 60;
                ctx.fillStyle = `rgb(${brilho}, ${brilho}, ${brilho})`;
                ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2); ctx.fill();
            }
            const texture = new THREE.CanvasTexture(canvas);
            texture.wrapS = THREE.RepeatWrapping;
            texture.wrapT = THREE.RepeatWrapping;
            texture.repeat.set(12, 12);
            texture.anisotropy = 4;
            return texture;
        }

        function criarChao() {
            const material = new THREE.MeshStandardMaterial({
                map: criarTexturaPedraEscura(),
                roughness: 0.9, metalness: 0.1,
                emissive: new THREE.Color(0x111111), emissiveIntensity: 0.05
            });
            const mesh = new THREE.Mesh(new THREE.PlaneGeometry(100, 100), material);
            mesh.rotation.x = -Math.PI / 2;
            mesh.receiveShadow = true;
            scene.add(mesh);
            const grid = new THREE.GridHelper(100, 100, 0x333355, 0x222244);
            grid.position.y = 0.03;
            grid.material.opacity = 0.12;
            grid.material.transparent = true;
            scene.add(grid);
        }

        function criarMuroPedra() {
            const raio = RAIO_MURO, altura = 4.5, seg = 80;
            const textura = (() => {
                const c = document.createElement('canvas');
                c.width = 1024; c.height = 512;
                const ctx = c.getContext('2d');
                ctx.fillStyle = '#3a3a44';
                ctx.fillRect(0, 0, 1024, 512);
                const bw = 1024 / 12, bh = 512 / 6;
                for (let row = 0; row < 6; row++) {
                    for (let col = 0; col < 12; col++) {
                        const dx = (row % 2 === 0) ? 0 : bw * 0.5;
                        const x = col * bw + dx, y = row * bh;
                        const tom = 60 + Math.random() * 50;
                        ctx.fillStyle = `rgb(${tom+10}, ${tom}, ${tom-5})`;
                        ctx.fillRect(x, y, bw - 2, bh - 2);
                        ctx.strokeStyle = '#2a2a30';
                        ctx.lineWidth = 2;
                        ctx.strokeRect(x, y, bw - 2, bh - 2);
                    }
                }
                const tex = new THREE.CanvasTexture(c);
                tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
                tex.repeat.set(3, 2);
                return tex;
            })();
            const material = new THREE.MeshStandardMaterial({
                map: textura, roughness: 0.85, metalness: 0.05,
                emissive: new THREE.Color(0x111111), emissiveIntensity: 0.05,
                side: THREE.DoubleSide
            });
            const muro = new THREE.Mesh(new THREE.CylinderGeometry(raio, raio, altura, seg, 4, true), material);
            muro.position.y = altura / 2;
            muro.castShadow = true;
            muro.receiveShadow = true;
            scene.add(muro);

            const matAnel = new THREE.MeshStandardMaterial({ color: 0x444455, roughness: 0.9 });
            const anelBase = new THREE.Mesh(new THREE.TorusGeometry(raio, 0.15, 12, seg), matAnel);
            anelBase.rotation.x = Math.PI / 2;
            anelBase.position.y = 0.1;
            scene.add(anelBase);
            const anelTopo = anelBase.clone();
            anelTopo.position.y = altura;
            scene.add(anelTopo);

            const matPilar = new THREE.MeshStandardMaterial({ color: 0x555566, roughness: 0.9 });
            for (let i = 0; i < 24; i++) {
                const ang = (i / 24) * Math.PI * 2;
                const x = Math.cos(ang) * (raio + 0.2), z = Math.sin(ang) * (raio + 0.2);
                const viga = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.12, altura, 6), matPilar);
                viga.position.set(x, altura / 2, z);
                viga.castShadow = true;
                scene.add(viga);
                const esfera = new THREE.Mesh(new THREE.SphereGeometry(0.12, 5, 5), matPilar);
                esfera.position.set(x, altura + 0.05, z);
                scene.add(esfera);
            }
        }

        // ============================================================
        //  7. PORTAL PRETO
        // ============================================================
        function criarPortalPretoEstrelas() {
            const grupo = new THREE.Group();
            grupo.position.set(0, 2.25, 19.2);
            grupo.lookAt(0, 2.25, 0);

            const raio = 2.5;
            const disco = new THREE.Mesh(
                new THREE.CircleGeometry(raio, 48),
                new THREE.MeshStandardMaterial({ color: 0x000000, emissive: 0x111122, emissiveIntensity: 0.2,
                    transparent: true, opacity: 0.92, side: THREE.DoubleSide })
            );
            disco.position.z = 0.01;
            grupo.add(disco);

            const numEstrelas = 400;
            const posEst = new Float32Array(numEstrelas * 3);
            const cores = new Float32Array(numEstrelas * 3);
            for (let i = 0; i < numEstrelas; i++) {
                const ang = Math.random() * Math.PI * 2, r = Math.sqrt(Math.random()) * raio * 0.95;
                posEst[i*3] = Math.cos(ang) * r;
                posEst[i*3+1] = Math.sin(ang) * r;
                posEst[i*3+2] = (Math.random() - 0.5) * 0.15;
                const b = 0.5 + Math.random() * 0.5;
                cores[i*3] = b * 0.8;
                cores[i*3+1] = b * 0.8;
                cores[i*3+2] = 1.0;
            }
            const geoEst = new THREE.BufferGeometry();
            geoEst.setAttribute('position', new THREE.BufferAttribute(posEst, 3));
            geoEst.setAttribute('color', new THREE.BufferAttribute(cores, 3));
            const estrelas = new THREE.Points(geoEst, new THREE.PointsMaterial({
                size: 0.08, vertexColors: true, transparent: true, opacity: 0.9,
                blending: THREE.AdditiveBlending, depthWrite: false, sizeAttenuation: true
            }));
            estrelas.position.z = 0.02;
            grupo.add(estrelas);

            const anel = new THREE.Mesh(
                new THREE.TorusGeometry(raio * 0.98, 0.06, 16, 64),
                new THREE.MeshStandardMaterial({ color: 0x445577, emissive: 0x223355, emissiveIntensity: 0.4,
                    transparent: true, opacity: 0.5 })
            );
            anel.position.z = 0.03;
            anel.rotation.x = Math.PI / 2;
            grupo.add(anel);

            const luz = new THREE.PointLight(0x4466aa, 0.4, 6);
            luz.position.set(0, 0, 0.4);
            grupo.add(luz);

            grupo.userData = { estrelas, anel, luz };
            scene.add(grupo);
            portalPretoEstrelas = grupo;
        }

        // ============================================================
        //  8. EVENTOS DE INTERAÇÃO
        // ============================================================
        function ocultarInstrucoes() {
            const p = document.getElementById('instrucoes');
            if (p && p.style.opacity !== '0') {
                p.style.opacity = '0';
                setTimeout(() => p.style.display = 'none', 600);
            }
        }

        function onTouchStart(e) {
            e.preventDefault();
            ocultarInstrucoes();
            const meio = window.innerWidth / 2;
            for (let t of e.changedTouches) {
                if (t.clientX < meio && !touchEsquerdo.ativo) {
                    touchEsquerdo.ativo = true;
                    touchEsquerdo.id = t.identifier;
                    touchEsquerdo.inicioX = t.clientX;
                    touchEsquerdo.inicioY = t.clientY;
                    touchEsquerdo.deltaX = 0;
                    touchEsquerdo.deltaY = 0;
                } else if (t.clientX >= meio && !touchDireito.ativo) {
                    touchDireito.ativo = true;
                    touchDireito.id = t.identifier;
                    touchDireito.ultimoX = t.clientX;
                    touchDireito.ultimoY = t.clientY;
                }
            }
        }

        function onTouchMove(e) {
            e.preventDefault();
            for (let t of e.changedTouches) {
                if (touchEsquerdo.ativo && t.identifier === touchEsquerdo.id) {
                    touchEsquerdo.deltaX = t.clientX - touchEsquerdo.inicioX;
                    touchEsquerdo.deltaY = t.clientY - touchEsquerdo.inicioY;
                } else if (touchDireito.ativo && t.identifier === touchDireito.id) {
                    const dx = t.clientX - touchDireito.ultimoX;
                    const dy = t.clientY - touchDireito.ultimoY;
                    cameraEuler.setFromQuaternion(camera.quaternion);
                    cameraEuler.y -= dx * velVisao;
                    cameraEuler.x -= dy * velVisao;
                    cameraEuler.x = Math.max(-Math.PI/2, Math.min(Math.PI/2, cameraEuler.x));
                    camera.quaternion.setFromEuler(cameraEuler);
                    touchDireito.ultimoX = t.clientX;
                    touchDireito.ultimoY = t.clientY;
                }
            }
        }

        function onTouchEnd(e) {
            e.preventDefault();
            for (let t of e.changedTouches) {
                if (touchEsquerdo.ativo && t.identifier === touchEsquerdo.id) {
                    touchEsquerdo.ativo = false;
                    touchEsquerdo.id = null;
                } else if (touchDireito.ativo && t.identifier === touchDireito.id) {
                    touchDireito.ativo = false;
                    touchDireito.id = null;
                }
            }
        }

        function onKeyDown(e) {
            const k = e.key.toLowerCase();
            if (['w','a','s','d'].includes(k)) { teclas[k] = true; e.preventDefault(); ocultarInstrucoes(); }
            if (k === 't') {
                gerarVelaTeste();
                e.preventDefault();
            }
            if (k === 'escape' && document.pointerLockElement) document.exitPointerLock();
        }
        function onKeyUp(e) {
            const k = e.key.toLowerCase();
            if (['w','a','s','d'].includes(k)) { teclas[k] = false; e.preventDefault(); }
        }
        function onCanvasClick() {
            if (!document.pointerLockElement) renderer.domElement.requestPointerLock();
        }
        function onPointerLockChange() {
            mousePreso = document.pointerLockElement === renderer.domElement;
            crosshair.classList.toggle('visivel', mousePreso);
            document.body.style.cursor = mousePreso ? 'none' : 'default';
        }
        function onMouseMove(e) {
            if (mousePreso) {
                const dx = e.movementX || 0, dy = e.movementY || 0;
                cameraEuler.setFromQuaternion(camera.quaternion);
                cameraEuler.y -= dx * velVisao;
                cameraEuler.x -= dy * velVisao;
                cameraEuler.x = Math.max(-Math.PI/2, Math.min(Math.PI/2, cameraEuler.x));
                camera.quaternion.setFromEuler(cameraEuler);
                ocultarInstrucoes();
            }
        }
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        // ============================================================
        //  9. MOVIMENTO E PORTAL
        // ============================================================
        function atualizarMovimento(dt) {
            let mx = 0, my = 0;
            if (touchEsquerdo.ativo) {
                mx = Math.max(-1, Math.min(1, touchEsquerdo.deltaX / 50));
                my = Math.max(-1, Math.min(1, touchEsquerdo.deltaY / 50));
            } else {
                if (teclas.w) my = -1;
                else if (teclas.s) my = 1;
                if (teclas.d) mx = 1;
                else if (teclas.a) mx = -1;
                if (mx !== 0 && my !== 0) { mx *= 0.7071; my *= 0.7071; }
            }
            if (mx !== 0 || my !== 0) {
                let dir = new THREE.Vector3(mx, 0, my);
                cameraEuler.setFromQuaternion(camera.quaternion);
                dir.applyAxisAngle(new THREE.Vector3(0, 1, 0), cameraEuler.y);
                if (dir.length() > 1) dir.normalize();
                const vel = Math.min(1, Math.sqrt(mx*mx + my*my)) * velMovimento * dt;
                let novaPos = camera.position.clone().addScaledVector(dir, vel);
                const dist = Math.sqrt(novaPos.x*novaPos.x + novaPos.z*novaPos.z);
                if (dist < RAIO_MURO) {
                    camera.position.copy(novaPos);
                } else {
                    const ang = Math.atan2(novaPos.z, novaPos.x);
                    camera.position.x = Math.cos(ang) * (RAIO_MURO - 0.1);
                    camera.position.z = Math.sin(ang) * (RAIO_MURO - 0.1);
                }
                camera.position.y = alturaOlhos;
            }
        }

        function verificarPortal() {
            const pos = camera.position;
            if (pos.x >= areaPortal.minX && pos.x <= areaPortal.maxX &&
                pos.z >= areaPortal.minZ && pos.z <= areaPortal.maxZ &&
                !jaRedirecionouPortal) {
                jaRedirecionouPortal = true;
                aviso.textContent = 'Moneroverse...';
                aviso.classList.add('visivel');
                setTimeout(() => {
                    window.open(DESTINO_MONEROVERSE, '_blank');
                    aviso.classList.remove('visivel');
                }, 400);
            } else if (!(pos.x >= areaPortal.minX && pos.x <= areaPortal.maxX &&
                        pos.z >= areaPortal.minZ && pos.z <= areaPortal.maxZ)) {
                jaRedirecionouPortal = false;
            }
        }

        // ============================================================
        //  10. LOOP PRINCIPAL
        // ============================================================
        function animarPortalPreto(time) {
            if (!portalPretoEstrelas) return;
            const d = portalPretoEstrelas.userData;
            d.anel.rotation.z = time * 0.4;
            d.luz.intensity = 0.3 + 0.2 * Math.sin(time * 1.2);
        }

        function animate() {
            requestAnimationFrame(animate);
            const dt = Math.min(clock.getDelta(), 0.05);
            const elapsed = clock.elapsedTime;

            atualizarMovimento(dt);
            atualizarVelas(dt);
            animarPortalPreto(elapsed);
            verificarPortal();

            renderer.render(scene, camera);
        }

        // ============================================================
        //  11. INICIAR
        // ============================================================
        window.onload = init;
    </script>
</body>
</html>
